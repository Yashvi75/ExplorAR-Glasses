# Google Maps Platform (Geocoding + Directions + Places)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# OpenAI API Key (for intelligent context and voice processing)
OPENAI_API_KEY=your_openai_api_key_here

# Google Cloud Translation API v2 (simple REST key — no SDK)
GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here

# OpenWeatherMap (free tier works for weather)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# OCR.space API (free tier: https://ocr.space/ocrapi)
OCR_API_KEY=your_ocr_space_api_key_here
